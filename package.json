{
  "name": "ticker-tracker-service",
  "version": "1.0.0",
  "description": "Real-time Exchange Ticker Tracker Service with Redis persistence",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "watch:binance-spot": "node src/index.js watch binance --type spot --debug",
    "watch:bybit-spot": "node src/index.js watch bybit --type spot --debug",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --testPathPattern=unit --config jest.config.js",
    "test:integration": "jest --testPathPattern=integration --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:coverage": "jest --coverage --config jest.config.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js' 'tests/**/*.js'"
  },
  "keywords": [
    "ticker",
    "exchange",
    "ccxt",
    "redis",
    "realtime",
    "websocket",
    "trading"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ccxt": "^4.2.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
