# ============================================================================
# TICKER TRACKER SERVICE - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values.
# All values shown are defaults and can be overridden by CLI flags.
# ============================================================================

# --- CORE EXCHANGE CONFIGURATION ---
# Exchange name (binance, bybit, kraken, etc.)
# MARKET_TYPE=spot|swap (overridable via --type)
# SYMBOL_LIMIT=5000 (max symbols to track, overridable via --limit)
# BATCH_SIZE=100 (symbols per connection, overridable via --batch-size)
MARKET_REFRESH_INTERVAL=300000

# --- SUBSCRIPTION & TIMING ---
# Delay between successive subscription requests (ms)
# Settable via --subscription-delay CLI flag
SUBSCRIPTION_DELAY=100

# --- REDIS CONFIGURATION ---
# Redis connection URL
# Formats: redis://localhost:6379, rediss://secure-redis:6379, localhost:6379
REDIS_URL=localhost:6379

# Redis batching behavior
# When true, ticker updates are batched and flushed periodically
REDIS_BATCHING=true

# How often to flush batched Redis writes (ms)
REDIS_FLUSH_MS=1000

# Maximum number of ticker updates to batch before flushing
REDIS_MAX_BATCH=1000

# Only write to Redis if the ticker value has changed
REDIS_ONLY_ON_CHANGE=true

# Minimum interval between consecutive Redis writes for the same symbol (ms)
# 0 = no minimum (write every change)
REDIS_MIN_INTERVAL_MS=0

# --- PROXY CONFIGURATION (Optional) ---
# Disable all proxy usage (use direct connections only)
NO_PROXY=false

# Proxy provider name (e.g., oxylabs, bright-data)
# Leave empty for no proxy
PROXY_PROVIDER=

# Proxy seller key (for some providers)
PROXY_SELLER_KEY=

# Oxylabs credentials
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# Proxy port range (if using Oxylabs)
OXYLABS_PORT_START=10000
OXYLABS_PORT_END=10010

# --- NETWORK CONFIGURATION (Optional) ---
# Comma-separated list of local IPv4 addresses to bind outbound connections to
# Example: 192.168.1.100,192.168.1.101,192.168.1.102
LOCAL_IPS=

# --- MONITORING & DEBUG ---
# Enable verbose debug logging
DEBUG=false

# Maximum memory usage before alerting (MB)
MEMORY_LIMIT=1024

# --- SUBSCRIPTION MODE ---
# When true, prefer watchTickers (all-at-once) if supported by exchange
# When false, allow per-symbol watchTicker subscriptions
WATCH_TICKERS=true
